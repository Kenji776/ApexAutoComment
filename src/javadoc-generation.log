=== REQUEST: 	@TestVisible
	private static void handleLoyaltyProgramSaveResultErrors(
		Database.SaveResult[] results,
		List<LoyaltyProgramMember> lpmList,
		List<Guest_Master_Guest_Detail__c> records,
		Map<Id, String> failedEvents
	) {
		List<Integer> failedIndices = new List<Integer>();
		for (Integer i = 0; i < results.size(); i++) {
			if (!results[i].isSuccess()) {
				LoyaltyProgramMember lpm = lpmList[i];
				String errorMsg = results[i].getErrors().size() > 0
					? results[i].getErrors()[0].getMessage()
					: 'Unknown error';
				for (Guest_Master_Guest_Detail__c record : records) {
					if (
						record.Ultraclub_Id__c == null ||
						lpm.MembershipNumber == null
					) {
						continue;
					}
					if (
						lpm.MembershipNumber ==
						record.Ultraclub_Id__c.format().replace(',', '')
					) {
						if (!failedEvents.containsKey(record.Source_Id__c)) {
							failedEvents.put(record.Source_Id__c, errorMsg);
							break; // Only add the first matching record's error message
						}
					}
				}
				failedIndices.add(i);
			}
		}
		for (Integer i = failedIndices.size() - 1; i >= 0; i--) {
			lpmList.remove(failedIndices[i]);
		}
	} (2026-03-18T21:47:34.475Z) ===


