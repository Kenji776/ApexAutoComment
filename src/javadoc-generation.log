				false
			);
			handleLoyaltyProgramSaveResultErrors(
				results5,
				mapping.createLoyaltyProgramMembers,
				records,
				failedEvents
			);
		}

		List<Account> allPrimaryAccounts = new List<Account>();
		allPrimaryAccounts.addAll(mapping.newAccounts);
		allPrimaryAccounts.addAll(mapping.existingAccounts);

		List<Account> allSecondaryAccounts = new List<Account>();

		allSecondaryAccounts.addAll(mapping.newAccounts2);
		allSecondaryAccounts.addAll(mapping.existingAccounts2);


		if (allPrimaryAccounts.isEmpty() || allSecondaryAccounts.isEmpty()) {
			logger.warn('All Primary Accounts or All Secondary Accounts are empty. Primary Accounts: ' + allPrimaryAccounts.size() + '. All Secondary Accounts ' + allSecondaryAccounts.size() + '.');
		}

		try {
			List<Id> allAccountIds = new List<Id>();
			for (Account acc : allPrimaryAccounts) {
				allAccountIds.add(acc.Id);
			}
			for (Account acc : allSecondaryAccounts) {
				allAccountIds.add(acc.Id);
			}

			Map<Id, Account> allAccountsMap = new Map<Id, Account>(
				[
					SELECT Id, PersonContactId, SSG_Guest_Name_ID__pc
					FROM Account
					WHERE Id IN :allAccountIds
				]
			);

			List<Account> updatedPrimaryAccounts = new List<Account>();
			for (Account acc : allPrimaryAccounts) {
				Account account = allAccountsMap.get(acc.Id);
				if (account != null) {
					updatedPrimaryAccounts.add(account);
				}
			}

			Map<Id, Account> secondaryAccountsMap = new Map<Id, Account>();
			for (Account acc : allSecondaryAccounts) {
				Account accountWithContact = allAccountsMap.get(acc.Id);
				if (accountWithContact != null) {
					secondaryAccountsMap.put(acc.Id, accountWithContact);
				}
			}

			Set<Id> replacedSecondaryAccountIds = cleanupReplacedSecondaryGuestAcrs(updatedPrimaryAccounts);

			if (!replacedSecondaryAccountIds.isEmpty()) {
				List<Account> oldSecondariesToClear = new List<Account>();
				for (Id accId : replacedSecondaryAccountIds) {
					oldSecondariesToClear.add(new Account(Id = accId, SSG_Guest_Name_ID__pc = null));
				}
				Logger.info(
					'performOptimizedDMLOperations: Clearing SSG_Guest_Name_ID__pc on ' +
					oldSecondariesToClear.size() + ' old secondary account(s)'
				);
				Database.update(oldSecondariesToClear, false);

				List<Account> filteredSecondaryAccounts = new List<Account>();
				for (Account acc : allSecondaryAccounts) {
					if (!replacedSecondaryAccountIds.contains(acc.Id)) {
						filteredSecondaryAccounts.add(acc);
					}
				}
				Logger.info(
					'performOptimizedDMLOperations: Excluded ' +
					(allSecondaryAccounts.size() - filteredSecondaryAccounts.size()) +
					' replaced secondary account(s) from ACR rebuild'
				);
				allSecondaryAccounts = filteredSecondaryAccounts;
			}

			List<AccountContactRelation> accountContactRelations = buildAccountContactRelations(
				updatedPrimaryAccounts,
				allSecondaryAccounts,
				secondaryAccountsMap
			);

			cleanupSecondaryGuestInfo(records);

			insertAccountContactRelations(
				accountContactRelations,
				updatedPrimaryAccounts,
				records,
				failedEvents
			);

			

			LoyaltyProgram loyaltyProgram = getLoyaltyProgram();
			if (loyaltyProgram == null) {
				Logger.error(
					'GuestMasterGuestDetailService: Loyalty Program not found: Sandals Select Rewards'
				);
			} else {
				List<LoyaltyProgramMember> loyaltyProgramMembers = buildLoyaltyProgramMembers(
					updatedPrimaryAccounts,
					records,
					loyaltyProgram
				);
				insertLoyaltyProgramMembers(
					loyaltyProgramMembers,
					records,
					failedEvents
				);
			}
		} catch (Exception e) {
			Logger.error(
				'GuestMasterGuestDetailService: Error in performOptimizedDMLOperations: ' +
				e.getMessage()
			);
			throw e;
		} finally {
			Logger.saveLog();
		}
	} (2026-03-18T21:36:38.431Z) ===


