				records,
				failedEvents
			);
		}

		List<Account> allPrimaryAccounts = new List<Account>();
		allPrimaryAccounts.addAll(mapping.newAccounts);
		allPrimaryAccounts.addAll(mapping.existingAccounts);

		List<Account> allSecondaryAccounts = new List<Account>();

		allSecondaryAccounts.addAll(mapping.newAccounts2);
		allSecondaryAccounts.addAll(mapping.existingAccounts2);


		if (allPrimaryAccounts.isEmpty() || allSecondaryAccounts.isEmpty()) {
