	private static Set<Id> cleanupReplacedSecondaryGuestAcrs(
		List<Account> primaryAccounts
	) {
		Set<Id> replacedSecondaryAccountIds = new Set<Id>();

		if (primaryAccounts == null || primaryAccounts.isEmpty()) {
			return replacedSecondaryAccountIds;
		}

		Set<Id> primaryAccountIds = new Set<Id>();
		Set<Id> primaryContactIds = new Set<Id>();
		for (Account acc : primaryAccounts) {
			if (acc.Id != null) {
				primaryAccountIds.add(acc.Id);
			}
			if (acc.PersonContactId != null) {
				primaryContactIds.add(acc.PersonContactId);
			}
		}

		Logger.info(
			'cleanupReplacedSecondaryGuestAcrs: Checking for stale secondary ACRs on ' +
			primaryAccountIds.size() + ' primary account(s)'
		);

		Set<Id> acrIdsToDelete = new Set<Id>();

		for (AccountContactRelation acr : [
			SELECT Id, AccountId, ContactId, Roles
			FROM AccountContactRelation
			WHERE AccountId IN :primaryAccountIds
			AND Roles INCLUDES ('Primary Guest')
		]) {
			Logger.info(
				'cleanupReplacedSecondaryGuestAcrs: Queuing stale Primary-Guest ACR for deletion. ' +
				'Id: ' + acr.Id + ', AccountId: ' + acr.AccountId + ', ContactId: ' + acr.ContactId
			);
			acrIdsToDelete.add(acr.Id);
		}

		for (AccountContactRelation acr : [
			SELECT Id, AccountId, ContactId, Roles
			FROM AccountContactRelation
			WHERE ContactId IN :primaryContactIds
			AND Roles INCLUDES ('Secondary Guest')
		]) {
			Logger.info(
				'cleanupReplacedSecondaryGuestAcrs: Queuing stale Secondary-Guest ACR for deletion. ' +
				'Id: ' + acr.Id + ', AccountId: ' + acr.AccountId + ', ContactId: ' + acr.ContactId
			);
			acrIdsToDelete.add(acr.Id);
			if (!primaryAccountIds.contains(acr.AccountId)) {
				replacedSecondaryAccountIds.add(acr.AccountId);
			}
		}

		if (!acrIdsToDelete.isEmpty()) {
			Logger.info(
				'cleanupReplacedSecondaryGuestAcrs: Deleting ' + acrIdsToDelete.size() + ' stale ACR record(s). ' +
				'Old secondary account(s) excluded from rebuild: ' + replacedSecondaryAccountIds
			);
			Database.delete(new List<Id>(acrIdsToDelete), false);
		} else {
			Logger.info('cleanupReplacedSecondaryGuestAcrs: No stale ACRs found — nothing to delete');
		}

		return replacedSecondaryAccountIds;
	} (2026-03-18T21:24:31.285Z) ===


