=== REQUEST: 	@TestVisible
	private static void handleSaveAccountContactRelationResultErrors(
		Database.SaveResult[] results,
		List<AccountContactRelation> accountContactRelationList,
		List<Account> records,
		List<Guest_Master_Guest_Detail__c> originalRecords,
		Map<Id, String> failedEvents
	) {
		List<Integer> failedIndices = new List<Integer>();
		for (Integer i = 0; i < results.size(); i++) {
			if (!results[i].isSuccess()) {
				AccountContactRelation accContact = accountContactRelationList[
					i
				];
				Account acc;
				for (Account accRecord : records) {
					if (accRecord.Id == accContact.AccountId) {
						acc = accRecord;
						break;
					}
				}
				String errorMsg = results[i].getErrors().size() > 0
					? results[i].getErrors()[0].getMessage()
					: 'Unknown error';
				if (acc == null) {
					continue; // Skip this iteration if no account found
				}
				Logger.error(
					'handleSaveResultErrors: Failed to insert Account. Index: ' +
						i +
						', SSG_Guest_Name_ID__pc: ' +
						acc.SSG_Guest_Name_ID__pc +
						', Error: ' +
						errorMsg
				);
				for (Guest_Master_Guest_Detail__c record : originalRecords) {
					String key = record.Guest_Name_Id__c.format()
						.replace(',', '');
					if (acc.SSG_Guest_Name_ID__pc == key) {
						if (!failedEvents.containsKey(record.Source_Id__c)) {
							failedEvents.put(record.Source_Id__c, errorMsg);
						}
						break; // Only add the first matching record's error message
					}
				}
				failedIndices.add(i);
			}
		}
		for (Integer i = failedIndices.size() - 1; i >= 0; i--) {
			accountContactRelationList.remove(failedIndices[i]);
		}
	} (2026-03-18T22:00:23.238Z) ===


