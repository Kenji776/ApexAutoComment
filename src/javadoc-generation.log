			Logger.info('Clearing SSG Guest Name Id from  ' + mapping.oldSecondaryMatchedAccounts.size() + ' secondary accounts');
			list<Database.saveResult> cleanedAccountResults = clearSSGGuestNameIdsFromAccounts(mapping.oldSecondaryMatchedAccounts);
			
			handleSaveResultErrors(
				cleanedAccountResults,
				mapping.oldSecondaryMatchedAccounts,
				records,
				failedEvents
			);

			List<AccountContactRelation> acrsToRemove = [SELECT Id 
														 FROM AccountContactRelation 
														 WHERE Roles INCLUDES('Secondary Guest') 
														 AND Account.Id IN :mapping.oldSecondaryMatchedAccounts];
			Logger.info('Deleting  ' + acrsToRemove.size() + ' ACR records for old secondary accounts');
			database.delete(acrsToRemove);
		}*/


		if (!allNewAccounts.isEmpty()) {
			Logger.info('Inserting  ' + allNewAccounts.size() + ' new PRIMARY accounts');
			Database.SaveResult[] insertResults = Database.insert(
				allNewAccounts,
				false
			);
			if (!newAccounts1StartIndex.isEmpty()) {
				Database.SaveResult[] results1 = new List<Database.SaveResult>(
					mapping.newAccounts.size()
				);
				for (Integer i = 0; i < mapping.newAccounts.size(); i++) {
					results1[i] = insertResults[newAccounts1StartIndex[0] + i];
				}
				handleSaveResultErrors(
					results1,
					mapping.newAccounts,
					records,
					failedEvents
				);
			}

			if (!newAccounts2StartIndex.isEmpty()) {
				Logger.info('Inserting  ' + mapping.newAccounts2.size() + ' new SECONDARY accounts');

				Database.SaveResult[] results2 = new List<Database.SaveResult>(
					mapping.newAccounts2.size()
				);
				for (Integer i = 0; i < mapping.newAccounts2.size(); i++) {
					results2[i] = insertResults[newAccounts2StartIndex[0] + i];
				}
				handleSaveResultErrors(
					results2,
					mapping.newAccounts2,
					records,
					failedEvents
				);
			}
		}

		if (!existingAccounts1ToUpdate.isEmpty()) {
			Logger.info('UPDATING  ' + existingAccounts1ToUpdate.size() + ' existing PRIMARY accounts');

			Database.SaveResult[] results3 = Database.update(
