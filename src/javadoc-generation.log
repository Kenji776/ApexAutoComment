	private static void performOptimizedDMLOperations(
		GuestMasterGuestDetailMapper.MappingResult mapping,
		List<Guest_Master_Guest_Detail__c> records,
		Map<Id, String> failedEvents
	) {
		List<Account> allNewAccounts = new List<Account>();
		List<Integer> newAccounts1StartIndex = new List<Integer>();
		List<Integer> newAccounts2StartIndex = new List<Integer>();

		if (!mapping.newAccounts.isEmpty()) {
			newAccounts1StartIndex.add(allNewAccounts.size());
			for (Account acc : mapping.newAccounts) {
				allNewAccounts.add(acc);
			}
		}

		if (!mapping.newAccounts2.isEmpty()) {
			newAccounts2StartIndex.add(allNewAccounts.size());
			for (Account acc : mapping.newAccounts2) {
				allNewAccounts.add(acc);
			}
		}

		List<Account> existingAccounts1ToUpdate = new List<Account>();
		List<Account> existingAccounts2ToUpdate = new List<Account>();
		Set<Id> queuedExistingAccountIds = new Set<Id>();

		for (Account acc : mapping.existingAccounts) {
			if (
				acc == null ||
				acc.Id == null ||
				queuedExistingAccountIds.contains(acc.Id)
			) {
				continue;
			}
			existingAccounts1ToUpdate.add(acc);
			queuedExistingAccountIds.add(acc.Id);
		}

		for (Account acc : mapping.existingAccounts2) {
			if (
				acc == null ||
				acc.Id == null ||
				queuedExistingAccountIds.contains(acc.Id)
			) {
				continue;
			}
			existingAccounts2ToUpdate.add(acc);
			queuedExistingAccountIds.add(acc.Id);
		}

		/*
