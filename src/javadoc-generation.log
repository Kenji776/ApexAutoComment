=== REQUEST:     public static List<Account> getContactCountsByAccount(List<Account> accounts) {
        Map<Id, Integer> contactCounts = new Map<Id, Integer>();

        TriggerLogicController.log('getContactCountsByAccount', TriggerLogicController.LogLevel.F_START);

        if (accounts == null || accounts.isEmpty()) {
            TriggerLogicController.log('No accounts provided for calculation. Returning.', TriggerLogicController.LogLevel.ERROR);
            return accounts;
        }

        List<Id> accountIds = new List<Id>(TriggerLogicController.extractIds(accounts));

        if (accountIds.isEmpty()) {
            TriggerLogicController.log('No IDs could be extracted from accounts (running in before_insert context?). Returning.', TriggerLogicController.LogLevel.ERROR);
            return accounts;
        }

        List<AggregateResult> results = [
            SELECT AccountId, COUNT(Id) contactCount
            FROM Contact
            WHERE AccountId IN :accountIds
            GROUP BY AccountId
        ];

        TriggerLogicController.log('Got aggregate result data for ' + results.size() + ' account records');

        for (AggregateResult ar : results) {
            Id accountId = (Id) ar.get('AccountId');
            Integer count = (Integer) ar.get('contactCount');
            contactCounts.put(accountId, count);
        }

        for (Id acctId : accountIds) {
            if (!contactCounts.containsKey(acctId)) {
                contactCounts.put(acctId, 0);
            }
        }

        TriggerLogicController.log(contactCounts);

        List<Account> accountsToUpdate = new List<Account>();
        for (Account acct : accounts) {
            if (acct.Id != null && contactCounts.containsKey(acct.Id)) {
                Account updated = new Account(
                    Id = acct.Id,
                    Contact_Count__c = contactCounts.get(acct.Id)
                );
                accountsToUpdate.add(updated);
            }
        }

        if (!accountsToUpdate.isEmpty()) {
            try {
                update accountsToUpdate;
                TriggerLogicController.log('Updated ' + accountsToUpdate.size() + ' accounts with contact counts.');
            } catch (Exception e) {
                TriggerLogicController.log('Error updating accounts: ' + e.getMessage(), TriggerLogicController.LogLevel.ERROR);
            }
        }

        TriggerLogicController.log('getContactCountsByAccount', TriggerLogicController.LogLevel.F_END);

        return accountsToUpdate;
    } (2025-10-05T22:44:33.315Z) ===


