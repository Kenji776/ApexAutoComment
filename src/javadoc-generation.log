					String guestNameId = record.Guest_Name_Id__c.format()
						.replace(',', '');
					String secondGuestKey = 'SecondGuest_' + guestNameId;
					if (
						acc.SSG_Guest_Name_ID__pc == guestNameId ||
						acc.SSG_Guest_Name_ID__pc == secondGuestKey
					) {
						if (!failedEvents.containsKey(record.Source_Id__c)) {
							failedEvents.put(record.Source_Id__c, errorMsg);
						}
						break; // Only add the first matching record's error message
					}
				}
				failedIndices.add(i);
			}
		}
		for (Integer i = failedIndices.size() - 1; i >= 0; i--) {
			accountList.remove(failedIndices[i]);
