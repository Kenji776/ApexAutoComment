	private static List<LoyaltyProgramMember> buildLoyaltyProgramMembers(
		List<Account> updatedNewAccounts,
		List<Guest_Master_Guest_Detail__c> originalRecords,
		LoyaltyProgram loyaltyProgram
	) {
		Map<String, Guest_Master_Guest_Detail__c> recordsByGuestId = new Map<String, Guest_Master_Guest_Detail__c>();
		Set<String> ultraClubsIds = new Set<String>();

		for (Guest_Master_Guest_Detail__c original : originalRecords) {
			if (
				original.Ultraclub_Id__c != null &&
				original.Enrolled_Date__c != null
			) {
				String keyAcc = original.Guest_Name_Id__c.format()
					.replace(',', '');
				recordsByGuestId.put(keyAcc, original);
				String membershipNumber = original.Ultraclub_Id__c.format()
					.replace(',', '');
				ultraClubsIds.add(membershipNumber);
			}
		}

		List<LoyaltyProgramMember> existingMembers = LoyaltyProgramMemberSelector.selectByUltraClubIds(
			ultraClubsIds
		);
		Set<String> existingLpmKeys = new Set<String>();
		for (LoyaltyProgramMember lpm : existingMembers) {
			String key = lpm.MembershipNumber + '-' + lpm.ProgramId;
			existingLpmKeys.add(key);
		}

		List<LoyaltyProgramMember> loyaltyProgramMembers = new List<LoyaltyProgramMember>();
		for (Account acc : updatedNewAccounts) {
			Guest_Master_Guest_Detail__c original = recordsByGuestId.get(
				acc.SSG_Guest_Name_ID__pc
			);
			if (original != null) {
				String membershipNumber = original.Ultraclub_Id__c.format()
					.replace(',', '');
				String lpmKey = membershipNumber + '-' + loyaltyProgram.Id;
				if (!existingLpmKeys.contains(lpmKey)) {
					LoyaltyProgramMember lpm = new LoyaltyProgramMember();
					lpm.MemberStatus = 'Active';
					lpm.MemberType = 'Individual';
					lpm.MembershipNumber = membershipNumber;
					lpm.ProgramId = loyaltyProgram.Id;
					lpm.EnrollmentDate = DateUtility.parseDateTime(
							original.Enrolled_Date__c
						)
						?.Date();
					lpm.ContactId = acc.PersonContactId;
					loyaltyProgramMembers.add(lpm);
					existingLpmKeys.add(lpmKey); // Prevent duplicates in this run
				}
			}
		}
		return loyaltyProgramMembers;
	} (2026-03-18T21:55:05.757Z) ===


