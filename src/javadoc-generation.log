		private static List<AccountContactRelation> buildAccountContactRelations(
		List<Account> primaryAccounts,
		List<Account> secondaryAccounts,
		Map<Id, Account> secondaryAccountsMap
	) {
		Logger.info('Attempting to build ACR records for the following accounts');
		Logger.info('primaryAccounts: ' + JSON.serializePretty(primaryAccounts));
		Logger.info('secondaryAccounts: ' + JSON.serializePretty(secondaryAccounts));
		Logger.info('secondaryAccountsMap: ' + JSON.serializePretty(secondaryAccountsMap));

		List<AccountContactRelation> accountContactRelations = new List<AccountContactRelation>();

		for (Account primary : primaryAccounts) {
			for (Account secondary : secondaryAccounts) {

				/*
				if (primary.Id == secondary.Id) {
					Logger.warn('Skipping ACR — primary and secondary are the same account: ' + primary.Id);
					continue;
				}
					*/

				String expectedSecGuestKey = 'SecondGuest_' + primary.SSG_Guest_Name_ID__pc;
				if (secondary.SSG_Guest_Name_ID__pc != expectedSecGuestKey) {
					continue;
				}

				Account secondaryWithContact = secondaryAccountsMap.containsKey(secondary.Id)
					? secondaryAccountsMap.get(secondary.Id)
					: secondary;

				if (primary.PersonContactId == null) {
					Logger.warn('Skipping ACR — primary account missing PersonContactId: ' + primary.Id);
					continue;
				}
				if (secondaryWithContact.PersonContactId == null) {
					Logger.warn('Skipping ACR — secondary account missing PersonContactId: ' + secondary.Id);
					continue;
				}

				AccountContactRelation acrPrimary = new AccountContactRelation(
					AccountId = primary.Id,
					ContactId = secondaryWithContact.PersonContactId,
					Roles = 'Primary Guest'
				);
				accountContactRelations.add(acrPrimary);

				AccountContactRelation acrSecondary = new AccountContactRelation(
					AccountId = secondary.Id,
					ContactId = primary.PersonContactId,
					Roles = 'Secondary Guest'
				);
				accountContactRelations.add(acrSecondary);
			}
		}

		Logger.info(' AccountContactRelations: ' + JSON.serializePretty(accountContactRelations));

		return accountContactRelations;
	} (2026-03-18T22:10:12.742Z) ===


