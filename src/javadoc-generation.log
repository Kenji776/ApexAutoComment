	public static void cleanupSecondaryGuestInfo(
		list<Guest_Master_Guest_Detail__c> recordsToProcess
	) {
		Logger.info('Preparing to cleanup secondary guest info for ' + recordsToProcess.size() + ' Guest_Master_Guest_Detail__c records');
		List<Account> accountsToClear = new List<Account>();
		List<String> guestNameIdsToQuery = new List<String>();
		Map<Id, Id> accIdToPersonContactIdMap = new Map<Id, Id>();
		List<Account> accountsToClearSSGId = new List<Account>();
		List<Id> acrsToDelete = new List<Id>();

		for (Guest_Master_Guest_Detail__c thisRecord : recordsToProcess) {
			if (
				String.isBlank(thisRecord.First_Name2__c) &&
				String.isBlank(thisRecord.Last_Name2__c) &&
				thisRecord.Guest_Name_Id__c != null
			) {
				Logger.info(
					'GMGD record with empty firstname2 and lastname2 found. With id: '+thisRecord.Id
				);
				guestNameIdsToQuery.add(
					SSGCacheManager.formatFieldForLookup(
						thisRecord.Guest_Name_Id__c
					)
				);
			}
		}

		for (Account thisAccount : [
			SELECT Id, PersonContactId
			FROM Account
			WHERE SSG_Guest_Name_ID__pc IN :guestNameIdsToQuery
		]) {
			accIdToPersonContactIdMap.put(
				thisAccount.Id,
				thisAccount.PersonContactId
			);
		}

		set<id> primaryContactIds = new set<id>();
		
		for (AccountContactRelation thisACR : [
			SELECT AccountId, ContactId, Id, Roles
			FROM AccountContactRelation
			WHERE
				ContactId IN :accIdToPersonContactIdMap.values()
				AND Roles INCLUDES ('Secondary Guest')
		]) {
			logger.info('Found ACR Record to Delete with Id: ' + thisACR.Id + '\nRole: ' + thisACR.Roles + '\nAccountId:'+thisAcr.AccountId+'\nMatched On ContactId:'+thisAcr.ContactId);
			acrsToDelete.add(thisACR.Id);
			primaryContactIds.add(thisACR.contactId);
			accountsToClearSSGId.add(
				new Account(
					id = thisACR.accountId,
					SSG_Guest_Name_ID__pc = null
				)
			);
		}


		logger.info('primaryContactIds: ' + primaryContactIds);

		/*
		The found ACR has an account that links to the secondary contact a contact id that links to the primary contact.
		The remaining ACR is linked to the primary. However it is recorded there by its account id. So we need to query for the 
		ACR where the accounts related contact is in the set of those we collected

		*/
		for (AccountContactRelation thisACR : [
			SELECT AccountId, ContactId, Id, Roles, Account.PersonContactId
			FROM AccountContactRelation
			WHERE
				Account.PersonContactId IN :primaryContactIds
				AND Roles INCLUDES ('Primary Guest')
		]) {
			logger.info('Found ACR Record to Delete with Id: ' + thisACR.Id + '\nRole: ' + thisACR.Roles + '\nAccountId:'+thisAcr.AccountId+'\nContactId:'+thisAcr.ContactId+'\nMatched On Person Contact On Account: ' + Account.PersonContactId);
			acrsToDelete.add(thisACR.Id);
		}

		logger.info('Deleting ' + acrsToDelete.size() + ' ACR Records');
		if (!acrsToDelete.isEmpty()) {
			database.delete(acrsToDelete, false);
		}

		logger.info('Cleaing SSG ID From from ' + accountsToClearSSGId.size() + ' Account Records');
		if (!accountsToClearSSGId.isEmpty()) {
			database.update(accountsToClearSSGId, false);
		}
	} (2026-03-18T22:00:26.547Z) ===


