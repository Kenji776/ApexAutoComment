	private static void insertAccountContactRelations(
		List<AccountContactRelation> accountContactRelations,
		List<Account> updatedNewAccounts,
		List<Guest_Master_Guest_Detail__c> originalRecords,
		Map<Id, String> failedEvents
	) {
		if (accountContactRelations.isEmpty()) {
			return;
		}

		Set<Id> accountIds = new Set<Id>();
		Set<Id> contactIds = new Set<Id>();
		for (AccountContactRelation acr : accountContactRelations) {
			accountIds.add(acr.AccountId);
			contactIds.add(acr.ContactId);
		}

		Map<String, Boolean> existingRelationMap = new Map<String, Boolean>();
		for (AccountContactRelation acr : [
			SELECT AccountId, ContactId
			FROM AccountContactRelation
			WHERE AccountId IN :accountIds AND ContactId IN :contactIds
		]) {
			existingRelationMap.put(acr.AccountId + '-' + acr.ContactId, true);
		}

		List<AccountContactRelation> relationsToInsert = new List<AccountContactRelation>();
		for (AccountContactRelation acr : accountContactRelations) {
			String key = acr.AccountId + '-' + acr.ContactId;
			if (!existingRelationMap.containsKey(key)) {
				relationsToInsert.add(acr);
			}
		}

		Logger.info('Preparing To Insert ACR Records (list after deduplication): ' + JSON.serializePretty(relationsToInsert));


		if (!relationsToInsert.isEmpty()) {
			Database.SaveResult[] results = Database.insert(
				relationsToInsert,
				false
			);
			handleSaveAccountContactRelationResultErrors(
				results,
				relationsToInsert,
				updatedNewAccounts,
				originalRecords,
				failedEvents
			);
		}
	} (2026-03-18T21:32:00.257Z) ===


