=== REQUEST:     public static void updateLead(List<CheckList__c> newLst,Map<Id,CheckList__c> oldMap){
        List<Lead> leadToUpdate = new List<Lead>();
        Set<Id> leadIds = new Set<Id>();
        for(CheckList__c cl:newLst){
            if(cl.Lead__c != null && cl.Status__c != oldMap.get(cl.Id).Status__c ){
                leadIds.add(cl.Lead__c);
            }
        }
        if(!leadIds.isEmpty()){
            for(Lead l:[SELECT Id,PendingDocuments__c, (SELECT Id,Status__c FROM CheckList__r) FROM Lead WHERE ID IN:leadIds]){
                if(!l.CheckList__r.isEmpty()){
                    Boolean documentsApproved = false;
                    for(CheckList__c cl:l.CheckList__r){
                        if(cl.Status__c != 'Approved'){
                            documentsApproved = true;
                            break;
                        }
                    }
                    if(documentsApproved==true){
                        l.PendingDocuments__c = 'Yes';
                    }else{
                        l.PendingDocuments__c = 'No';
                    }
                    leadToUpdate.add(l);
                }
            }
            if(!leadToUpdate.isEmpty()){
                update leadToUpdate;
            }
        }
    } (2025-07-16T00:22:53.804Z) ===


