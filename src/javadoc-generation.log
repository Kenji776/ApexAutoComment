        List<String> parts = new List<String>();

        if(bankRecon.Bank_Transaction__c != null) parts.add(String.valueOf(bankRecon.Bank_Transaction__c));
        else(parts.add('MISSING_BANK_TRANSACTION'));


        if(bankRecon.Vehicle_Transaction__c != null) parts.add(String.valueOf(bankRecon.Vehicle_Transaction__c));
        else(parts.add('MISSING_VEHICLE_TRANSACTION'));

        if(bankRecon.VIN__c != null) parts.add(String.valueOf(bankRecon.Vin__c));
        else(parts.add('MISSING_VIN'));

        if(bankRecon.Invoice__c != null) parts.add(String.valueOf(bankRecon.Invoice__c));
        else(parts.add('MISSING_INVOICE'));

        return Flexdrive_SharedUtilities.hashString(String.join(parts, '-')).left(100);
    } (2025-07-16T00:23:04.048Z) ===


